# Frontend Supabase config
VITE_SUPABASE_URL=https://your-new-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# For backend edge functions, set the Moodle DB secrets in Supabase Dashboard > Edge Functions > Secrets:
# MOODLE_DB_HOST=
# MOODLE_DB_PORT=5432
# MOODLE_DB_USER=
# MOODLE_DB_PASSWORD=
# MOODLE_DB_NAME=
# Optional: control TLS behavior for Moodle DB
# MOODLE_DB_TLS=prefer   # default: try TLS, fallback to no TLS
# MOODLE_DB_TLS=require  # force TLS
# MOODLE_DB_TLS=disable  # force plaintext connection
